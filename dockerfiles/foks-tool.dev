FROM golang:1.24-alpine AS builder

RUN apk add --no-cache ca-certificates

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY lib lib
COPY proto proto
COPY server server
RUN CGO_ENABLED=0 GOOS=linux GOFLAGS="-tags=noresinit" go build -C server/foks-tool -o ../../foks-tool .

WORKDIR /
RUN mv /build/foks-tool /foks-tool
RUN rm -rf /build /go

ENTRYPOINT ["/foks-tool"]