FROM golang:1.24-alpine AS builder

RUN apk add --no-cache ca-certificates

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY lib lib
COPY proto proto
COPY server server
RUN CGO_ENABLED=0 GOOS=linux GOFLAGS="-tags=noresinit" go build -C server/foks-server -o ../../foks-server .

WORKDIR /
RUN mv /build/foks-server /foks-server
RUN rm -rf /build /go

RUN ls -lsR /
RUN uname -m

ENTRYPOINT ["/foks-server"]